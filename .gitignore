# =========================
# Model / Training Outputs
# (용량 큰 학습 산출물 제외)
# =========================

# checkpoints
outputs/**/checkpoint-*/

# model weights
outputs/**/*.bin
outputs/**/*.pt
outputs/**/*.pth
outputs/**/*.safetensors

# trainer states
outputs/**/optimizer.pt
outputs/**/scheduler.pt
outputs/**/training_args.bin
outputs/**/trainer_state.json
outputs/**/rng_state.pth
outputs/**/scaler.pt

# tokenizer
outputs/**/tokenizer.json
outputs/**/tokenizer_config.json

# prediction cache
outputs/**/*.npy
outputs/**/*probabilities.csv
outputs/**/*predictions.csv

# 분석 중 생성되는 대용량 오답 파일
outputs/**/wrong_predictions.csv

